---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import ProductList from '../../components/ProductList.astro';
import { useTranslations } from '../../i18n/utils';

export const prerender = false;

const { lang } = Astro.params;
const t = useTranslations(lang as any);

// Récupération des filtres actuels depuis l'URL
const { searchParams } = Astro.url;
const currentStyle = searchParams.get('style') || t('filter.allStyles');
const currentApp = searchParams.get('app') || t('filter.allApps');
const currentSpace = searchParams.get('space') || t('filter.allSpaces');
const currentMat = searchParams.get('mat') || t('filter.allMats');
const currentColor = searchParams.get('color') || '';

// Récupération des filtres dynamiques (Catégories) depuis l'API FastAPI
const categoriesResponse = await fetch(`${import.meta.env.PUBLIC_API_URL}/api/products/categories`);
const categories = await categoriesResponse.json();

const spaces = ['Living room', 'Bedroom', 'Bathroom', 'Dining room', 'Kitchen', 'Outdoor'];
const colors = [
    { name: lang === 'fr' ? 'Blanc' : 'White', hex: '#FFFFFF', class: 'bg-white border-slate-200' },
    { name: lang === 'fr' ? 'Gris' : 'Grey', hex: '#808080', class: 'bg-gray-400' },
    { name: lang === 'fr' ? 'Noir' : 'Black', hex: '#000000', class: 'bg-black' },
    { name: lang === 'fr' ? 'Beige' : 'Beige', hex: '#F5F5DC', class: 'bg-[#f5f5dc]' }
];
---

<Layout title={`${t('nav.collections')} | STRADIP SARL`}>
    <Navbar />

    <div class="h-24 md:h-26 w-full bg-white "></div>
    <section class="py-20 bg-gradient-subtle">
        <div class="mx-auto max-w-7xl px-6 lg:px-10 text-center">
            <div class="text-accent text-sm tracking-[0.3em] uppercase mb-4">
                {t('collections.label')}
            </div>
            
            <h1 class="font-display text-5xl md:text-6xl text-foreground mb-6">
                {t('collections.title').split(' ').slice(0, -2).join(' ')} <span class="italic font-light bg-gradient-primary bg-clip-text text-transparent">{t('collections.title').split(' ').slice(-2).join(' ')}</span>
            </h1>
            
            <p class="text-muted-foreground max-w-2xl mx-auto text-lg">
                {t('collections.desc')}
            </p>
        </div>
    </section>

    <main class="max-w-[1600px] mx-auto px-4 md:px-16 lg:px-12 py-10 md:py-20 min-h-screen bg-white relative z-20 shadow-[0_-20px_50px_rgba(0,0,0,0.05)]">
        
        <!-- MOBILE FILTER TOGGLE -->
        <div class="lg:hidden mb-8 flex justify-between items-center">
            <button 
                id="mobileFilterOpen" 
                type="button"
                onclick="toggleFilterDrawer(true)"
                class="flex items-center gap-3 bg-slate-900 text-white px-6 py-4 rounded-xl text-[10px] font-black uppercase tracking-[2px] shadow-lg active:scale-95 transition-all relative z-[40]"
            >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-2a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/></svg>
                {t('filter.interactive')}
            </button>
            <span class="text-[10px] font-bold uppercase tracking-widest text-slate-400">
                <span id="mobile-product-count"></span>
            </span>
        </div>

        <div class="flex flex-col lg:flex-row gap-12">

            <!-- FILTER SIDEBAR (Desktop & Mobile Drawer) -->
            <div id="filterSidebar" class="fixed inset-0 z-[100] bg-white lg:relative lg:inset-auto lg:z-0 lg:bg-transparent lg:w-80 shrink-0 translate-x-full lg:translate-x-0 transition-transform duration-500 overflow-y-auto lg:overflow-visible">
                <!-- Overlay for mobile (closes drawer on click) -->
                <div id="filterOverlay" class="fixed inset-0 bg-black/20 backdrop-blur-sm lg:hidden hidden z-[-1]" onclick="toggleFilterDrawer(false)"></div>
                
                <div class="p-8 lg:p-0 lg:border-r lg:border-slate-100 lg:pr-12 bg-white lg:bg-transparent min-h-full">
                    <!-- Mobile Close Header -->
                    <div class="flex justify-between items-center mb-10 lg:hidden">
                        <h2 class="text-xl font-black uppercase tracking-tighter text-slate-900">{t('filter.interactive')}</h2>
                        <button type="button" onclick="toggleFilterDrawer(false)" class="p-2 bg-slate-100 rounded-full text-slate-500">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                        </button>
                    </div>

                    <form id="filterForm" class="space-y-12">
                        <!-- Styles -->
                        <div>
                            <h3 class="text-[0.7rem] font-black uppercase tracking-[3px] text-stradip-cyan mb-6">{t('filter.style')}</h3>
                            <div class="flex flex-col space-y-3">
                                {[
                                    {val: 'Tous les styles', label: t('filter.allStyles')},
                                    {val: 'Carreaux Standard', label: t('filter.style.standard')},
                                    {val: 'Décorations & Motifs', label: t('filter.style.deco')}
                                ].map((s) => (
                                    <label class="flex items-center space-x-3 cursor-pointer group">
                                        <input type="radio" name="style" value={s.val} class="w-4 h-4 accent-stradip-cyan" checked={currentStyle === s.val || currentStyle === s.label} />
                                        <span class="text-sm font-medium text-slate-500 group-hover:text-stradip-blue transition">{s.label}</span>
                                    </label>
                                ))}
                            </div>
                        </div>

                        <!-- Pose/App -->
                        <div>
                            <h3 class="text-[0.7rem] font-black uppercase tracking-[3px] text-slate-900 mb-6">{t('filter.app')}</h3>
                            <div class="flex flex-col space-y-3">
                                {[
                                    {val: 'Toutes les poses', label: t('filter.allApps')},
                                    {val: 'Sol (Floor)', label: t('filter.app.sol')},
                                    {val: 'Mur (Wall)', label: t('filter.app.mur')}
                                ].map((a) => (
                                    <label class="flex items-center space-x-3 cursor-pointer group">
                                        <input type="radio" name="app" value={a.val} class="w-4 h-4 accent-stradip-cyan" checked={currentApp === a.val || currentApp === a.label} />
                                        <span class="text-sm font-medium text-slate-500 group-hover:text-stradip-blue transition">{a.label}</span>
                                    </label>
                                ))}
                            </div>
                        </div>

                        <!-- Espaces -->
                        <div>
                            <h3 class="text-[0.7rem] font-black uppercase tracking-[3px] text-slate-900 mb-6">{t('filter.spaces')}</h3>
                            <div class="flex flex-col space-y-3">
                                <label class="flex items-center space-x-3 cursor-pointer group border-b border-slate-50 pb-2">
                                    <input type="radio" name="space" value="Toutes les pièces" class="w-4 h-4 accent-stradip-cyan" checked={currentSpace === 'Toutes les pièces' || currentSpace === t('filter.allSpaces')} />
                                    <span class="text-xs font-bold uppercase tracking-widest text-slate-900">{t('filter.allSpaces')}</span>
                                </label>
                                {spaces.map((s) => (
                                    <label class="flex items-center space-x-3 cursor-pointer group">
                                        <input type="radio" name="space" value={s} class="w-4 h-4 accent-stradip-cyan" checked={currentSpace === s} />
                                        <span class="text-sm font-medium text-slate-500 group-hover:text-stradip-blue transition">{s}</span>
                                    </label>
                                ))}
                            </div>
                        </div>

                        <!-- Matières -->
                        <div>
                            <h3 class="text-[0.7rem] font-black uppercase tracking-[3px] text-slate-900 mb-6">{t('filter.mats')}</h3>
                            <div class="flex flex-col space-y-3">
                                <label class="flex items-center space-x-3 cursor-pointer group border-b border-slate-50 pb-2">
                                    <input type="radio" name="mat" value="Toutes les matières" class="w-4 h-4 accent-stradip-cyan" checked={currentMat === 'Toutes les matières' || currentMat === t('filter.allMats')} />
                                    <span class="text-xs font-bold uppercase tracking-widest text-slate-900">{t('filter.allMats')}</span>
                                </label>
                                {categories.map((c: any) => (
                                    <label class="flex items-center space-x-3 cursor-pointer group">
                                        <input type="radio" name="mat" value={c.id} class="w-4 h-4 accent-stradip-cyan" checked={currentMat === String(c.id)} />
                                        <span class="text-sm font-medium text-slate-500 group-hover:text-stradip-blue transition">{c.nom_matiere}</span>
                                    </label>
                                ))}
                            </div>
                        </div>

                        <!-- Couleurs -->
                        <div>
                            <h3 class="text-[0.7rem] font-black uppercase tracking-[3px] text-slate-900 mb-6">{t('filter.colors')}</h3>
                            <div class="grid grid-cols-4 gap-4">
                                {colors.map((c) => (
                                    <label class="relative cursor-pointer group flex flex-col items-center">
                                        <input type="radio" name="color" value={c.hex} class="peer sr-only" checked={currentColor === c.hex} />
                                        <div class={`w-10 h-10 rounded-full ${c.class} border peer-checked:ring-2 peer-checked:ring-stradip-cyan peer-checked:ring-offset-2 transition-all shadow-sm`}></div>
                                        <span class="text-[0.55rem] mt-2 font-bold uppercase text-gray-400 peer-checked:text-slate-900">{c.name}</span>
                                    </label>
                                ))}
                            </div>
                        </div>

                        <div class="pt-6">
                            <button type="button" id="resetBtn" class="flex items-center justify-center w-full py-4 border border-slate-100 text-[0.65rem] font-black uppercase tracking-[3px] text-slate-400 hover:text-red-500 hover:border-red-100 transition-all">
                                ✕ {t('filter.reset')}
                            </button>
                        </div>

                        <!-- Mobile Footer Action -->
                        <div class="pt-10 lg:hidden">
                            <button type="button" onclick="toggleFilterDrawer(false)" class="w-full bg-stradip-blue text-white py-5 rounded-2xl font-black uppercase tracking-[2px] text-[11px] shadow-2xl">
                                Voir les résultats
                            </button>
                        </div>
                    </form>
                </div>
            </div>
            <script is:inline>
                function toggleFilterDrawer(open) {
                    const sidebar = document.getElementById('filterSidebar');
                    const overlay = document.getElementById('filterOverlay');
                    if (open) {
                        sidebar.classList.remove('translate-x-full');
                        overlay.classList.remove('hidden');
                        document.body.style.overflow = 'hidden';
                    } else {
                        sidebar.classList.add('translate-x-full');
                        overlay.classList.add('hidden');
                        document.body.style.overflow = '';
                    }
                }
            </script>

            <section class="flex-1">
                <div class="hidden lg:flex justify-between items-center mb-10 pb-6 border-b border-slate-50">
                    <span class="text-[0.7rem] font-bold uppercase tracking-widest text-gray-400">
                        {t('filter.interactive')} <span id="product-count" class="ml-2 text-stradip-cyan"></span>
                    </span>
                </div>

                <div id="product-grid-container" class="transition-opacity duration-300">
                    <ProductList />
                </div>

                <!-- PAGINATION DYNAMIQUE -->
                <div id="pagination-container" class="mt-24 flex justify-center items-center space-x-3">
                    <!-- Les boutons seront injectés ici par JS -->
                </div>
            </section>
        </div>
    </main>

    <Footer />
</Layout>

<script>
    const filterForm = document.getElementById('filterForm') as HTMLFormElement;
    const gridContainer = document.getElementById('product-grid-container');
    const paginationContainer = document.getElementById('pagination-container');
    const resetBtn = document.getElementById('resetBtn');
    const productCount = document.getElementById('product-count');
    const mobileProductCount = document.getElementById('mobile-product-count');
    
    // Mobile Drawer Elements
    const mobileFilterOpen = document.getElementById('mobileFilterOpen');
    const mobileFilterClose = document.getElementById('mobileFilterClose');
    const filterSidebar = document.getElementById('filterSidebar');
    const applyFiltersBtn = document.getElementById('applyFilters');

    let currentPage = 1;
    const limit = 12;

    function toggleFilterDrawer(open: boolean) {
        if (!filterSidebar) return;
        if (open) {
            filterSidebar.classList.remove('translate-x-full');
            document.body.style.overflow = 'hidden';
        } else {
            filterSidebar.classList.add('translate-x-full');
            document.body.style.overflow = '';
        }
    }

    mobileFilterOpen?.addEventListener('click', () => toggleFilterDrawer(true));
    mobileFilterClose?.addEventListener('click', () => toggleFilterDrawer(false));
    applyFiltersBtn?.addEventListener('click', () => toggleFilterDrawer(false));

    async function updateProducts(page = 1) {
        if (!gridContainer || !paginationContainer) return;

        currentPage = page;
        gridContainer.style.opacity = '0.5';
        
        const formData = new FormData(filterForm);
        const params = new URLSearchParams();

        // Pagination
        const skip = (currentPage - 1) * limit;
        params.append('skip', skip.toString());
        params.append('limit', limit.toString());

        // Filtres
        const style = formData.get('style');
        if (style && style !== 'Tous les styles' && style !== 'All Styles') params.append('style', style as string);

        const app = formData.get('app');
        if (app && app !== 'Toutes les poses' && app !== 'All Applications') params.append('type_pose', app as string);

        const space = formData.get('space');
        if (space && space !== 'Toutes les pièces' && space !== 'All Spaces') params.append('piece', space as string);

        const mat = formData.get('mat');
        if (mat && mat !== 'Toutes les matières' && mat !== 'All Materials') params.append('category_id', mat as string);

        const color = formData.get('color');
        if (color) params.append('couleur', color as string);

        // Update URL
        const displayParams = new URLSearchParams(params);
        displayParams.delete('skip');
        displayParams.delete('limit');
        if (currentPage > 1) displayParams.append('page', currentPage.toString());
        
        const newUrl = `${window.location.pathname}${displayParams.toString() ? '?' + displayParams.toString() : ''}`;
        window.history.pushState({}, '', newUrl);

        try {
            const response = await fetch(`${import.meta.env.PUBLIC_API_URL}/api/products/?${params.toString()}`);
            const data = await response.json();
            const products = data.items || [];
            const total = data.total || 0;

            const text = window.location.pathname.includes('/en') ? 'items' : 'articles';
            if (productCount) productCount.textContent = `(${total} ${text})`;
            if (mobileProductCount) mobileProductCount.textContent = `${total} ${text}`;

            // RENDER GRID
            if (products.length === 0) {
                const noProductsText = window.location.pathname.includes('/en') ? 'No products found.' : 'Aucun produit trouvé.';
                gridContainer.innerHTML = `<div class="text-center py-20"><p class="text-slate-400 italic">${noProductsText}</p></div>`;
            } else {
                let html = '<div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-x-10 gap-y-16 animate-fade-up">';
                products.forEach((p: any) => {
                    const imageUrl = p.image_url.startsWith('http') ? p.image_url : `${import.meta.env.PUBLIC_API_URL}${p.image_url}`;
                    const langPrefix = window.location.pathname.includes('/en') ? '/en' : '/fr';
                    html += `
                        <a href="${langPrefix}/produit/${p.id}" class="group block bg-white border border-slate-50 hover:shadow-2xl transition-all duration-500">
                            <div class="relative aspect-[5/4] overflow-hidden bg-slate-100">
                                <img src="${imageUrl}" alt="${p.nom}" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
                                ${p.style === 'Décoratif / Motif' ? '<span class="absolute top-4 right-4 bg-stradip-cyan text-white text-[0.6rem] font-black px-2 py-1 uppercase tracking-widest z-10">Déco</span>' : ''}
                            </div>
                            <div class="relative flex justify-between items-center p-4 bg-white overflow-hidden">
                                <div class="relative z-10">
                                    <h3 class="text-sm font-bold text-slate-800 uppercase tracking-widest">${p.nom}</h3>
                                    <div class="absolute -bottom-2 left-0 w-0 h-[2px] bg-stradip-cyan transition-all duration-500 group-hover:w-full"></div>
                                </div>
                                <div class="absolute right-0 top-0 h-full w-14 bg-stradip-blue text-white flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-300 translate-x-full group-hover:translate-x-0">
                                    <span class="text-xl">→</span>
                                </div>
                            </div>
                        </a>
                    `;
                });
                html += '</div>';
                gridContainer.innerHTML = html;
            }

            // RENDER PAGINATION
            renderPagination(total);

        } catch (error) {
            console.error("Erreur AJAX:", error);
        } finally {
            gridContainer.style.opacity = '1';
        }
    }

    function renderPagination(total: number) {
        if (!paginationContainer) return;
        const totalPages = Math.ceil(total / limit);
        
        if (totalPages <= 1) {
            paginationContainer.innerHTML = '';
            return;
        }

        let html = '';
        for (let i = 1; i <= totalPages; i++) {
            const activeClass = i === currentPage ? 'bg-stradip-blue text-white border-stradip-blue' : 'bg-white text-slate-400 border-slate-100 hover:border-stradip-cyan hover:text-stradip-cyan';
            html += `<button class="page-btn w-12 h-12 flex items-center justify-center text-[10px] font-black border transition-all ${activeClass}" data-page="${i}">${String(i).padStart(2, '0')}</button>`;
        }
        paginationContainer.innerHTML = html;

        paginationContainer.querySelectorAll('.page-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                const page = parseInt(btn.getAttribute('data-page') || '1');
                updateProducts(page);
                window.scrollTo({ top: 400, behavior: 'smooth' });
            });
        });
    }

    // Initialisation
    filterForm?.querySelectorAll('input').forEach(input => {
        input.addEventListener('change', () => updateProducts(1));
    });

    resetBtn?.addEventListener('click', () => {
        const radios = filterForm.querySelectorAll('input[type="radio"]') as NodeListOf<HTMLInputElement>;
        
        radios.forEach(radio => {
            const val = radio.value;
            if (['Tous les styles', 'Toutes les poses', 'Toutes les pièces', 'Toutes les matières'].includes(val)) {
                radio.checked = true;
            } else {
                radio.checked = false;
            }
        });

        window.history.pushState({}, '', window.location.pathname);
        updateProducts(1);
    });

    window.addEventListener('DOMContentLoaded', () => {
        updateProducts(1);
    });
</script>

<style>
    .font-serif { font-family: 'Playfair Display', serif; }
    
    @keyframes fadeUp {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .animate-fade-up {
        animation: fadeUp 1s ease-out forwards;
    }
</style>
