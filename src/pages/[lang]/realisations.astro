---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { useTranslations, useTranslatedPath } from '../../i18n/utils';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'fr' } },
  ];
}

const { lang } = Astro.params;
const t = useTranslations(lang as any);
const translatePath = useTranslatedPath(lang as any);

// Récupération des données depuis l'API FastAPI
const response = await fetch(`${import.meta.env.PUBLIC_API_URL}/api/projects/`);
const data = await response.json();
const rawProjects = data.items || data;

const projects = Array.isArray(rawProjects) ? rawProjects.map((p: any) => ({
  id: p.id,
  title: p.nom,
  category: p.ville, 
  location: p.ville,
  image: p.image_globale.startsWith('http') ? p.image_globale : `${import.meta.env.PUBLIC_API_URL}${p.image_globale}`,
  span: p.id % 3 === 1 ? "md:col-span-2 md:row-span-2" : "md:col-span-1 md:row-span-1"
})) : [];

const filters = [t('realisations.page.all'), ...new Set(projects.map((p: any) => p.category))];
---

<Layout title={`${t('nav.realisations')} | STRADIP SARL`}>
  <Navbar />

  <div class="pt-26"></div>
  <section class="relative h-[45vh] w-full flex flex-col bg-[url('https://images.unsplash.com/photo-1600607687920-4e2a09cf159d?q=80&w=2070')] bg-fixed bg-center bg-cover overflow-hidden">
    <div class="absolute inset-0 bg-[#0a1120]/60 backdrop-blur-[1px]"></div>
    <div class="relative z-10 flex-grow flex flex-col items-center justify-center text-center max-w-6xl mx-auto px-6 animate-fade-up">
        <span class="text-stradip-cyan text-[0.7rem] font-black uppercase tracking-[10px] mb-6 block">Portfolio</span>
        <h1 class="font-serif text-5xl md:text-7xl font-bold text-white tracking-tight leading-none uppercase">
            {t('realisations.page.title').split(' ')[0]} <br/> <span class="italic font-light text-stradip-cyan lowercase">{t('realisations.page.title').split(' ').slice(1).join(' ')}</span>
        </h1>
    </div>
  </section>

  <main class="relative z-20 bg-white min-h-screen shadow-[0_-20px_50px_rgba(0,0,0,0.05)]">
    <div class="max-w-[1400px] mx-auto px-6 py-20">
      
      <div class="flex flex-wrap justify-center gap-8 mb-20">
        {filters.map((f) => (
          <button class="text-[10px] font-black uppercase tracking-[3px] text-slate-400 hover:text-stradip-cyan transition-colors relative group pb-2">
            {f}
            <span class="absolute bottom-0 left-0 w-0 h-[2px] bg-stradip-cyan transition-all group-hover:w-full"></span>
          </button>
        ))}
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 auto-rows-[300px]">
        {projects.map((p: any) => (
          <div class={`group relative overflow-hidden bg-[#0a1628] ${p.span}`}>
            <img 
              src={p.image} 
              alt={p.title} 
              class="w-full h-full object-cover opacity-60 transition-all duration-1000 group-hover:scale-110 group-hover:opacity-30"
            />

            <div class="absolute inset-0 p-10 flex flex-col justify-end">
              <span class="text-stradip-cyan text-[8px] font-black uppercase tracking-[4px] mb-2 translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500">
                {p.category}
              </span>
              <h3 class="font-serif text-white text-3xl mb-1 italic">
                {p.title}
              </h3>
              <p class="text-white/40 text-[10px] uppercase tracking-widest font-light">
                {p.location}
              </p>
              
              <div class="w-0 h-[1px] bg-stradip-cyan mt-6 group-hover:w-full transition-all duration-700"></div>
            </div>

            <a href={translatePath(`/realisations/${p.id}`)} class="absolute inset-0 z-10"></a>
          </div>
        ))}
      </div>

      <div class="mt-32 text-center bg-slate-50 py-20 px-6 rounded-sm border border-slate-100">
        <h2 class="font-serif text-3xl text-slate-900 mb-6 italic">{t('realisations.page.question')}</h2>
        <p class="text-slate-500 max-w-xl mx-auto mb-10 font-light">{t('realisations.page.desc')}</p>
        <a href={translatePath('/#contact')} class="inline-block bg-[#0a1628] text-white px-12 py-5 text-[10px] font-black uppercase tracking-[3px] hover:bg-stradip-cyan transition-all duration-500 shadow-xl">
            {t('realisations.page.cta')}
        </a>
      </div>

    </div>
  </main>

  <Footer />
</Layout>

<style>
    .font-serif { font-family: 'Playfair Display', serif; }
    
    @keyframes fadeUp {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .animate-fade-up {
        animation: fadeUp 1.2s ease-out forwards;
    }
</style>
