---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { useTranslations, useTranslatedPath } from '../../i18n/utils';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'fr' } },
  ];
}

const { lang } = Astro.params;
const t = useTranslations(lang as any);
const translatePath = useTranslatedPath(lang as any);

// Récupération des données depuis l'API FastAPI
const response = await fetch(`${import.meta.env.PUBLIC_API_URL}/api/accessories/`);
const data = await response.json();
const rawAccessories = data.items || data;

const accessories = Array.isArray(rawAccessories) ? rawAccessories.map((acc: any) => ({
    id: acc.id,
    nom: acc.nom,
    categorie: acc.categorie_acc,
    image: acc.image_url.startsWith('http') ? acc.image_url : `${import.meta.env.PUBLIC_API_URL}${acc.image_url}`,
    desc: acc.description || (lang === 'fr' ? "Équipement professionnel sélectionné pour sa qualité et sa durabilité." : "Professional equipment selected for its quality and durability."),
    stock: acc.stock
})) : [];
---

<Layout title={`${t('nav.accessoires')} | STRADIP SARL`}>
    <Navbar />
    <div class="pt-26"></div>
    <main class="bg-white min-h-screen pb-24">
        <!-- HEADER : Inspiré de accessoires.php -->
        <header class="bg-[#0a1628] pt-15  pb-15 text-center text-white">
            <span class="text-stradip-cyan text-[0.6rem] font-black uppercase tracking-[5px] mb-4 block">
                {t('accessoires.label')}
            </span>
            <h1 class="font-serif text-5xl md:text-6xl font-bold uppercase tracking-tighter">
                {t('accessoires.title')}
            </h1>
            <p class="text-slate-400 mt-6 max-w-xl mx-auto font-light text-lg">
                {t('accessoires.desc')}
            </p>
        </header>

        <div class="max-w-7xl mx-auto px-6 md:px-12 py-20">
            <!-- GRID : Inspiré de accessoires.php -->
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
                {accessories.map((acc: any) => (
                    <a href={translatePath(`/accessoires/${acc.id}`)} class="group block bg-white border border-slate-100 hover:shadow-2xl transition-all duration-500 overflow-hidden">
                        <div class="relative aspect-[5/4] overflow-hidden bg-slate-50">
                            <img 
                                src={acc.image} 
                                alt={acc.nom} 
                                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                            />
                        </div>

                        <div class="p-6 pt-4">
                            <div class="flex justify-between items-center pt-4 border-t border-slate-50">
                                <h3 class="text-sm font-bold text-slate-800 uppercase tracking-widest leading-tight">
                                    {acc.nom}
                                </h3>
                                <span class="ml-2 text-slate-300 group-hover:text-stradip-cyan transition-colors text-xl">→</span>
                            </div>
                        </div>
                    </a>
                ))}
            </div>
        </div>
    </main>

    <Footer />
</Layout>

<style>
    .font-serif { font-family: 'Playfair Display', serif; }
</style>
