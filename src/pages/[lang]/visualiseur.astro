---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import { useTranslations } from '../../i18n/utils';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'fr' } },
  ];
}

const { lang } = Astro.params;
const t = useTranslations(lang as any);

// Simulation des pièces disponibles
const rooms = [
    { id: 'salon', name: t('visualiseur.room.salon'), img: '/rooms/living-room-mask.png' },
    { id: 'salle-de-bain', name: t('visualiseur.room.sdb'), img: '/rooms/bathroom-mask.png' },
    { id: 'cuisine', name: t('visualiseur.room.cuisine'), img: '/rooms/kitchen-mask.png' }
];

// On récupère les produits pour la sélection
let rawProducts = [];
try {
    const response = await fetch(`${import.meta.env.PUBLIC_API_URL}/api/products/`);
    if (response.ok) {
        const data = await response.json();
        rawProducts = Array.isArray(data) ? data : [];
    } else {
        console.error(`Erreur API Visualiseur: ${response.status} ${response.statusText}`);
    }
} catch (error) {
    console.error("Impossible de récupérer les produits pour le visualiseur:", error);
}

const tiles = rawProducts.map((p: any) => ({
    id: p.id?.toString() || Math.random().toString(),
    nom: p.nom || 'Sans nom',
    thumb: p.image_url?.startsWith('http') ? p.image_url : `${import.meta.env.PUBLIC_API_URL}${p.image_url || ''}`
}));
---

<Layout title={`${t('visualiseur.title')} | STRADIP`}>
    <Navbar />

    <main class="h-screen pt-20 flex flex-col lg:flex-row overflow-hidden bg-[#f8fafc]">
        
        <section class="flex-grow relative bg-slate-200 flex items-center justify-center p-4 md:p-12">
            <div class="relative w-full max-w-5xl aspect-video bg-white shadow-2xl overflow-hidden rounded-lg">
                <img id="room-display" src="/rooms/living-room.jpg" class="absolute inset-0 w-full h-full object-cover z-20" />
                
                <div 
                    id="tile-texture" 
                    class="absolute inset-0 z-10"
                    style="background-image: url('https://images.unsplash.com/photo-1615529328331-f8917597711f?w=800'); background-size: 200px;"
                ></div>
            </div>

            <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex gap-4 z-30">
                <button class="bg-white/90 backdrop-blur px-6 py-3 text-[10px] font-bold uppercase tracking-widest shadow-xl rounded-full hover:bg-stradip-cyan hover:text-white transition-all">{t('visualiseur.applyFloor')}</button>
                <button class="bg-white/90 backdrop-blur px-6 py-3 text-[10px] font-bold uppercase tracking-widest shadow-xl rounded-full hover:bg-stradip-cyan hover:text-white transition-all">{t('visualiseur.applyWall')}</button>
            </div>
        </section>

        <aside class="w-full lg:w-96 bg-white border-l border-slate-100 p-8 overflow-y-auto flex flex-col gap-10">
            
            <div>
                <h3 class="text-[10px] font-black uppercase tracking-[3px] text-stradip-cyan mb-6">{t('visualiseur.step1')}</h3>
                <div class="grid grid-cols-1 gap-4">
                    {rooms.map(room => (
                        <button class="flex items-center gap-4 p-3 border border-slate-100 rounded-xl hover:border-stradip-cyan transition-all text-left group">
                            <div class="w-16 h-12 bg-slate-200 rounded-lg overflow-hidden"></div>
                            <span class="text-sm font-bold text-slate-700 group-hover:text-stradip-blue">{room.name}</span>
                        </button>
                    ))}
                </div>
            </div>

            <div>
                <h3 class="text-[10px] font-black uppercase tracking-[3px] text-stradip-cyan mb-6">{t('visualiseur.step2')}</h3>
                <div class="grid grid-cols-2 gap-4">
                    {tiles.map(tile => (
                        <button class="tile-selector group" data-img={tile.thumb}>
                            <div class="aspect-square rounded-xl overflow-hidden border-2 border-transparent group-hover:border-stradip-cyan transition-all mb-2">
                                <img src={tile.thumb} class="w-full h-full object-cover" />
                            </div>
                            <span class="text-[10px] font-bold uppercase text-slate-400 block text-center leading-tight">{tile.nom}</span>
                        </button>
                    ))}
                </div>
            </div>

            <div class="mt-auto pt-8 border-t border-slate-100">
                <a href={lang === 'en' ? '/en/devis' : '/fr/devis'} class="block w-full text-center bg-[#0a1628] text-white py-5 text-[10px] font-black uppercase tracking-[3px] hover:bg-stradip-cyan transition-all">
                    {t('visualiseur.cta')}
                </a>
            </div>
        </aside>
    </main>
</Layout>

<script>
    const tileButtons = document.querySelectorAll('.tile-selector');
    const textureDiv = document.getElementById('tile-texture');

    tileButtons.forEach(btn => {
        btn.addEventListener('click', () => {
            const newImg = btn.getAttribute('data-img');
            if (textureDiv && newImg) {
                textureDiv.style.backgroundImage = `url('${newImg}')`;
            }
        });
    });
</script>