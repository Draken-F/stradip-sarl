---
// src/pages/admin/login.astro
import '../../styles/global.css';
---

<!doctype html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login | STRADIP Admin</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Inter:wght@100..900&display=swap" rel="stylesheet">
</head>
<body class="bg-[#0a1628] min-h-screen flex items-center justify-center p-4 font-sans">

    <div class="max-w-md w-full">
        <div class="text-center mb-10">
            <h1 class="font-serif text-3xl text-white tracking-widest uppercase">
                STRADIP<span class="text-stradip-cyan">ADMIN</span>
            </h1>
            <p class="text-white/50 text-xs mt-2 uppercase tracking-[3px]">Gestion de stock & Réalisations</p>
        </div>

        <div class="bg-white p-10 rounded-3xl shadow-2xl">
            <h2 class="text-xl font-bold text-slate-900 mb-8 uppercase tracking-tighter">Connexion sécurisée</h2>

            <form class="space-y-6" onsubmit="event.preventDefault(); window.location.href='/admin/dashboard'">
                <div>
                    <label class="block text-[0.6rem] font-black uppercase tracking-widest text-slate-400 mb-2">Identifiant</label>
                    <input type="text" name="username" required
                        class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:border-stradip-cyan focus:outline-none transition-all text-sm font-semibold">
                </div>

                <div>
                    <label class="block text-[0.6rem] font-black uppercase tracking-widest text-slate-400 mb-2">Mot de passe</label>
                    <input type="password" name="password" required
                        class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:border-stradip-cyan focus:outline-none transition-all">
                </div>

                <button type="submit"
                    class="w-full bg-stradip-blue text-white py-4 rounded-xl text-[0.7rem] font-black uppercase tracking-[3px] hover:bg-stradip-cyan transition-all duration-500 shadow-lg mt-4">
                    Entrer dans le Dashboard
                </button>
            </form>
        </div>

        <div class="mt-8 text-center">
            <a href="/" class="text-slate-500 text-[0.6rem] uppercase tracking-widest hover:text-white transition-colors">
                ← Retour au site public
            </a>
        </div>
    </div>

</body>
</html>
