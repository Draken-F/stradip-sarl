---
import { Image } from 'astro:assets';
import logo from '../assets/stradip-logo.png';

const currentPath = Astro.url.pathname;

const menuItems = [
    { name: 'Dashboard', href: '/admin/dashboard', icon: '📊' },
    { name: 'Catalogue Carreaux', href: '/admin/produits', icon: '📦' },
    { name: 'Accessoires', href: '/admin/accessoires', icon: '🛠️' },
    { name: 'Réalisations', href: '/admin/projets', icon: '🏗️' },
];
---

<aside class="w-64 bg-[#0a1628] text-white flex flex-col h-screen sticky top-0 shrink-0 shadow-2xl z-50">
    <div class="p-8 border-b border-white/5">
        <div class="flex items-center gap-3">
            <div class="w-10 h-10">
                <Image src={logo} alt="Logo Stradip" class="w-full h-full object-cover rounded" />
            </div>
            <div class="flex flex-col">
                <span class="text-lg font-bold tracking-tighter leading-none text-white">STRADIP</span>
                <span class="text-[8px] font-bold tracking-[3px] text-stradip-cyan leading-none mt-1 uppercase">Admin</span>
            </div>
        </div>
    </div>

    <nav class="flex-1 px-4 py-8 space-y-2 overflow-y-auto">
        {menuItems.map(item => (
            <a 
                href={item.href}
                class={`flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-bold uppercase tracking-widest transition-all ${
                    currentPath.startsWith(item.href) 
                    ? 'bg-stradip-cyan text-white shadow-lg shadow-stradip-cyan/20' 
                    : 'text-slate-400 hover:bg-white/5 hover:text-white'
                }`}
            >
                <span class="text-lg">{item.icon}</span>
                {item.name}
            </a>
        ))}
    </nav>

    <div class="p-4 border-t border-white/5 space-y-2">
        <a href="/" target="_blank" class="flex items-center gap-3 px-4 py-3 text-slate-400 hover:text-white text-[10px] font-bold uppercase tracking-widest transition">
            <span>👁️</span> Voir le site public
        </a>
        <a href="/admin/login" class="flex items-center gap-3 px-4 py-3 text-red-400 hover:bg-red-500/10 rounded-xl text-[10px] font-bold uppercase tracking-widest transition">
            <span>🚪</span> Déconnexion
        </a>
    </div>
</aside>
