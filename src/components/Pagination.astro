---
// src/components/Pagination.astro
---
<div class="flex justify-center items-center gap-2 mt-20">
    <button class="w-12 h-12 flex items-center justify-center rounded-xl border border-slate-200 hover:bg-stradip-blue hover:text-white transition-all">
        ←
    </button>
    
    <button class="w-12 h-12 flex items-center justify-center rounded-xl bg-stradip-blue text-white font-bold">1</button>
    <button class="w-12 h-12 flex items-center justify-center rounded-xl border border-slate-200 hover:border-stradip-cyan transition-all">2</button>
    <button class="w-12 h-12 flex items-center justify-center rounded-xl border border-slate-200 hover:border-stradip-cyan transition-all">3</button>
    
    <span class="px-2 text-slate-300">...</span>
    
    <button class="w-12 h-12 flex items-center justify-center rounded-xl border border-slate-200 hover:bg-stradip-blue hover:text-white transition-all">
        →
    </button>
</div>