---
// src/components/Contact.astro
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="contact" class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-6">
    
    <!-- HEADER SECTION -->
    <div class="text-center mb-20">
        <div class="flex items-center justify-center gap-4 mb-4">
            <span class="w-8 h-[1.5px] bg-stradip-cyan"></span>
            <span class="text-stradip-cyan text-[10px] tracking-[0.5em] font-bold uppercase">{t('contact.label')}</span>
            <span class="w-8 h-[1.5px] bg-stradip-cyan"></span>
        </div>
        <h2 class="font-serif text-4xl md:text-6xl text-slate-900 leading-tight">
            {t('contact.title')} <span class="italic text-stradip-blue font-light">{t('contact.title.italic')}</span>
        </h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
        
        <!-- SIDEBAR : INFOS GÉNÉRALES -->
        <aside class="lg:col-span-4 space-y-8">
            <div class="bg-[#0a1628] p-10 rounded-3xl text-white shadow-2xl relative overflow-hidden group">
                <!-- Décoration de fond -->
                <div class="absolute -top-10 -right-10 w-40 h-40 bg-stradip-cyan/10 rounded-full blur-3xl group-hover:bg-stradip-cyan/20 transition-colors"></div>
                
                <h3 class="text-stradip-cyan text-[10px] font-black uppercase tracking-[4px] mb-12 border-b border-white/10 pb-4">{t('contact.sidebar.title')}</h3>

                <div class="space-y-12">
                    <div class="space-y-6">
                        <p class="text-[9px] font-black uppercase tracking-[2px] text-white/40">{t('contact.sidebar.direction')}</p>
                        <div class="space-y-4">
                            <a href="tel:+237674500040" class="flex items-center group/link">
                                <div class="w-10 h-10 bg-white/5 rounded-full flex items-center justify-center border border-white/10 group-hover/link:border-stradip-cyan transition-all">
                                    <svg class="w-4 h-4 text-white/60 group-hover/link:text-stradip-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                                </div>
                                <span class="ml-4 text-sm font-bold tracking-tight group-hover/link:text-stradip-cyan transition-colors">+237 674 500 040</span>
                            </a>
                            <a href="https://wa.me/237674500040" class="flex items-center group/link">
                                <div class="w-10 h-10 bg-green-500/10 rounded-full flex items-center justify-center border border-green-500/20 group-hover/link:bg-green-500 transition-all">
                                    <svg class="w-5 h-5 text-green-500 group-hover/link:text-white" fill="currentColor" viewBox="0 0 24 24">
                                        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.72.94 3.675 1.439 5.711 1.439h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                                    </svg>
                                </div>
                                <span class="ml-4 text-sm font-bold tracking-tight group-hover/link:text-green-400 transition-colors">{t('contact.sidebar.whatsapp')}</span>
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Horaires -->
                <div class="mt-16 pt-10 border-t border-white/10">
                    <p class="text-[9px] font-black uppercase tracking-[2px] text-white/40 mb-4 text-center">{t('contact.sidebar.hours.title')}</p>
                    <div class="flex justify-between text-xs font-medium uppercase tracking-tighter">
                        <span class="text-white/60">{t('contact.sidebar.hours.week')}</span>
                        <span class="font-bold">08h00 - 18h00</span>
                    </div>
                    <div class="flex justify-between text-xs font-medium uppercase tracking-tighter mt-2">
                        <span class="text-white/60">{t('contact.sidebar.hours.sat')}</span>
                        <span class="font-bold">08h00 - 13h00</span>
                    </div>
                </div>
            </div>
        </aside>

        <!-- GRILLE DES VILLES -->
        <div class="lg:col-span-8 space-y-16">
            
            <!-- DOUALA -->
            <div class="space-y-8">
                <div class="flex items-center gap-6">
                    <span class="text-2xl">🏙️</span>
                    <h3 class="text-2xl font-bold uppercase tracking-[4px] text-slate-900 font-serif">Douala</h3>
                    <div class="flex-grow h-px bg-slate-100"></div>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div class="bg-slate-50/50 p-8 rounded-2xl border border-transparent hover:border-stradip-cyan hover:bg-white hover:shadow-2xl transition-all duration-500 group">
                        <span class="inline-block px-3 py-1 bg-stradip-cyan/10 text-stradip-cyan text-[9px] font-black uppercase tracking-widest rounded-full mb-6">{t('contact.city.showroom')}</span>
                        <h4 class="text-xl font-bold text-stradip-blue mb-3 uppercase tracking-tighter">Akwa - Liberté</h4>
                        <p class="text-sm text-slate-500 font-light leading-relaxed">Boulevard de la Liberté, face à l'Hôtel de l'Air. Exposition complète de nos collections exclusives.</p>
                    </div>
                    <div class="bg-slate-50/50 p-8 rounded-2xl border border-transparent hover:border-stradip-cyan hover:bg-white hover:shadow-2xl transition-all duration-500">
                        <span class="inline-block px-3 py-1 bg-slate-200 text-slate-500 text-[9px] font-black uppercase tracking-widest rounded-full mb-6">{t('contact.city.depot')}</span>
                        <h4 class="text-xl font-bold text-stradip-blue mb-3 uppercase tracking-tighter">Bonabéri</h4>
                        <p class="text-sm text-slate-500 font-light leading-relaxed">Ancienne route, 200m après le pont. Centre logistique pour enlèvements de grandes quantités.</p>
                    </div>
                </div>
            </div>

            <!-- YAOUNDÉ -->
            <!-- <div class="space-y-8">
                <div class="flex items-center gap-6">
                    <span class="text-2xl">🏛️</span>
                    <h3 class="text-2xl font-bold uppercase tracking-[4px] text-slate-900 font-serif">Yaoundé</h3>
                    <div class="flex-grow h-px bg-slate-100"></div>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div class="bg-slate-50/50 p-8 rounded-2xl border border-transparent hover:border-stradip-cyan hover:bg-white hover:shadow-2xl transition-all duration-500 group">
                        <span class="inline-block px-3 py-1 bg-stradip-cyan/10 text-stradip-cyan text-[9px] font-black uppercase tracking-widest rounded-full mb-6">{t('contact.city.showroom.boutique')}</span>
                        <h4 class="text-xl font-bold text-stradip-blue mb-3 uppercase tracking-tighter">Bastos - Cascade</h4>
                        <p class="text-sm text-slate-500 font-light leading-relaxed">Rue de la Cascade, Ambassade de Chine. Spécialisé dans le Marbre & formats Prestige.</p>
                    </div>
                    <div class="bg-slate-50/50 p-8 rounded-2xl border border-transparent hover:border-stradip-cyan hover:bg-white hover:shadow-2xl transition-all duration-500">
                        <span class="inline-block px-3 py-1 bg-slate-200 text-slate-500 text-[9px] font-black uppercase tracking-widest rounded-full mb-6">{t('contact.city.depot')}</span>
                        <h4 class="text-xl font-bold text-stradip-blue mb-3 uppercase tracking-tighter">Mvan</h4>
                        <p class="text-sm text-slate-500 font-light leading-relaxed">Entrée Sud de la ville, face à la gare routière. Hub de distribution pour la région Centre.</p>
                    </div>
                </div>
            </div> -->

        </div>
    </div>
  </div>
</section>