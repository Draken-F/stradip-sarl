---
// src/components/ProductCard.astro
import { getLangFromUrl, useTranslatedPath } from '../i18n/utils';

const { id, nom, image, style } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const translatePath = useTranslatedPath(lang);
---

<a href={translatePath(`/produit/${id}`)} class="group block bg-white border border-slate-50 hover:shadow-2xl transition-all duration-500">
    <!-- ZONE IMAGE -->
    <div class="relative aspect-[5/4] overflow-hidden bg-slate-100">
        <img 
            src={image} 
            alt={nom} 
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" 
        />
        
        {style === 'Décoratif' && (
            <span class="absolute top-4 right-4 bg-stradip-cyan text-white text-[0.6rem] font-black px-2 py-1 uppercase tracking-widest z-10">
                {lang === 'fr' ? 'Déco' : 'Deco'}
            </span>
        )}
    </div>

    <!-- ZONE INFO BLANCHE -->
    <div class="relative flex justify-between items-center p-4 bg-white overflow-hidden">
        <div class="relative z-10">
            <h3 class="text-sm font-bold text-slate-800 uppercase tracking-widest">
                {nom}
            </h3>
            <!-- Ligne Cyan Animée -->
            <div class="absolute -bottom-2 left-0 w-0 h-[2px] bg-stradip-cyan transition-all duration-500 group-hover:w-full"></div>
        </div>
        
        <!-- Carré Bleu Coulissant (Flèche) -->
        <!-- Note : w-14 utilisé pour correspondre aux standards Tailwind (56px) -->
        <div class="absolute right-0 top-0 h-full w-14 bg-stradip-blue text-white flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-300 translate-x-full group-hover:translate-x-0">
            <span class="text-xl">→</span>
        </div>
    </div>
</a>