---
const currentYear = new Date().getFullYear();
import { Image } from 'astro:assets';
import logo from '../assets/stradip-logo.png'; // Ton logo
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---

<footer class="bg-[#0a1120] text-gray-300 pt-20 pb-8 border-t border-white/5">
    <div class="max-w-7xl mx-auto px-6 md:px-16 lg:px-24">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-16 mb-16">

            <!-- BRANDING -->
            <div class="space-y-8">
                <div class="flex items-center gap-3">
                    <div class="w-14 h-14 ">
        <Image src={logo} alt="Logo Stradip" class="w-full h-full  object-cover" />
      </div>
                    <div class="flex flex-col">
                        <span class="text-xl font-bold tracking-tighter leading-none text-white">STRADIP</span>
                        <span class="text-[9px] font-bold tracking-[3px] text-stradip-cyan leading-none mt-1 uppercase">Sarl</span>
                    </div>
                </div>
                <p class="text-sm leading-relaxed text-gray-400 font-light max-w-xs">
                    {t('footer.description')}
                </p>
            </div>

            <!-- COLLECTIONS -->
            <div class="lg:pl-10">
                <h3 class="text-white font-bold uppercase tracking-[4px] text-[0.7rem] mb-8 border-b border-stradip-cyan/30 pb-3 inline-block">{t('footer.collections')}</h3>
                <ul class="space-y-4 text-sm font-light">
                    <li><a href={translatePath('/collections?cat=marbre')} class="hover:text-stradip-cyan transition-colors duration-300">{t('footer.marbre')}</a></li>
                    <li><a href={translatePath('/collections?cat=sol')} class="hover:text-stradip-cyan transition-colors duration-300">{t('footer.sol')}</a></li>
                    <li><a href={translatePath('/collections?cat=mur')} class="hover:text-stradip-cyan transition-colors duration-300">{t('footer.mur')}</a></li>
                    <li><a href={translatePath('/collections?cat=outdoor')} class="hover:text-stradip-cyan transition-colors duration-300">{t('footer.outdoor')}</a></li>
                </ul>
            </div>

            <!-- ENTREPRISE -->
            <div class="lg:pl-10">
                <h3 class="text-white font-bold uppercase tracking-[4px] text-[0.7rem] mb-8 border-b border-stradip-cyan/30 pb-3 inline-block">{t('footer.enterprise')}</h3>
                <ul class="space-y-4 text-sm font-light">
                    <li><a href={translatePath('/')} class="hover:text-stradip-cyan transition-colors duration-300">{t('nav.home')}</a></li>
                    <li><a href={translatePath('/collections')} class="hover:text-stradip-cyan transition-colors duration-300">{t('footer.catalogue')}</a></li>
                    <li><a href={translatePath('/realisations')} class="hover:text-stradip-cyan transition-colors duration-300">{t('nav.realisations')}</a></li>
                    <li><a href={translatePath('/#contact')} class="hover:text-stradip-cyan transition-colors duration-300">{t('nav.contact')}</a></li>
                </ul>
            </div>

            <!-- AGENCES -->
            <div>
                <h3 class="text-white font-bold uppercase tracking-[4px] text-[0.7rem] mb-8 border-b border-stradip-cyan/30 pb-3 inline-block">{t('footer.agencies')}</h3>
                <div class="space-y-8 text-[13px] font-light">

                    <div class="space-y-3">
                        <p class="text-stradip-cyan font-black text-[0.6rem] uppercase tracking-[2px]">Douala ({lang === 'fr' ? 'Siège' : 'HQ'})</p>
                        <p class="flex items-start text-gray-400">
                            <span class="mr-3 opacity-50">📍</span> Akwa, Boulevard de la Liberté
                        </p>
                        <p class="flex items-center text-gray-400">
                            <span class="mr-3 opacity-50">📞</span> +237 674 500 040
                        </p>
                    </div>

                    <div class="space-y-3">
                        <p class="text-stradip-cyan font-black text-[0.6rem] uppercase tracking-[2px]">Yaoundé</p>
                        <p class="flex items-start text-gray-400">
                            <span class="mr-3 opacity-50">📍</span> Bastos, Rue de la Cascade
                        </p>
                        <p class="flex items-center text-gray-400">
                            <span class="mr-3 opacity-50">📞</span> +237 6XX XXX XXX
                        </p>
                    </div>
                </div>
            </div>

        </div>

        <!-- BOTTOM BAR -->
        <div class="pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center text-[0.65rem] text-gray-500 uppercase tracking-[3px]">
            <p>&copy; {currentYear} STRADIP SARL. {t('footer.allRights')}</p>
            <p class="mt-4 md:mt-0">{t('footer.designBy')} <span class="text-white font-bold underline underline-offset-4 decoration-stradip-cyan/50">Georges Roland EPOLE</span></p>
        </div>
    </div>
</footer>

<script>
    // Smooth scroll pour les ancres
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', (e) => {
            const href = anchor.getAttribute('href');
            if (href && href.startsWith('#')) {
                e.preventDefault();
                const target = document.querySelector(href);
                if (target) {
                    target.scrollIntoView({
                        behavior: 'smooth'
                    });
                }
            }
        });
    });
</script>